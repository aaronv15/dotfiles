# ========== System ==========
# # waybar # apparently already installed?
# sudo pacman -S waybar

# on a laptop install tlp for power management
if [[ -z $LAPTOP ]]; then
   sudo pacman -S tlp ethtool smartmontools
   sudo systemctl enable tlp --now
fi

# install rsync
sudo pacman -S rsync

# install app picker/launcher fuzzel
sudo pacman -S fuzzel

# install zip/unzip
sudo pacman -S zip unzip

# install ranger fm
sudo pacman -S ranger

#install ter fonts
sudo pacman -S terminus-font

#install luakit browser
sudo pacman -S luakit

#install libnotify
sudo pacman -S libnotify

#install mako as notification daemon
sudo pacman -S mako

# Mirror stuff
sudo pacman -S reflector

# update vconsole font
sudo sed \
   --regexp-extended \
   --in-place=.bak  \
   --expression='/^FONT=/c\FONT=ter-128b' \
   /etc/vconsole.conf

# modify grub config
sudo sed \
   --regexp-extended \
   --in-place=.bak \
   --expression='/^GRUB_TIMEOUT_STYLE=/c\GRUB_TIMEOUT_STYLE=countdown' \
   --expression='/^GRUB_CMDLINE_LINUX_DEFAULT/s/ ?quiet//' \
   /etc/default/grub

# update grub to use modified config
sudo grub-mkconfig -o /boot/grub/grub.cfg

# Modify reflector args
sudo sed \
   --regexp-extended \
   --in-place=.bak \
   --expression='/^# --country/c\--country "South Africa"' \
   /etc/xdg/reflector/reflector.conf

# Enable reflector
sudo systemctl enable reflector.timer
sudo systemctl start reflector.timer


# enable keyd
sudo systemctl enable keyd --now

# setup ly
sudo pacman -S ly
# disable getty
sudo systemctl disable getty@.service
# enable ly on tty1
sudo systemctl enable ly@tty1.service
sudo ln -sT /etc/systemd/system/multi-user.target.wants/ly@tty1.service /etc/systemd/system/multi-user.target.wants/autovt@tty1.service

# enable getty on remaining tty's
sudo systemctl enable getty@tty{2..6}.service

sudo cp ~/.dotfiles/ly/config.ini /etc/ly/config.ini

# symlinks
sudo ln -sT ~/.dotfiles/keyd /etc/keyd

# ========== User ==========

# Set default shell to zsh
chsh -s /bin/zsh

# install fonts:
mkdir -p ~/Downloads
wget -O ~/Downloads/CascadiaMono.zip https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/CascadiaMono.zip
mkdir -p ~/.local/share/fonts # make font dir if not existing
unzip ~/Downloads/CascadiaMono.zip -d ~/.local/share/fonts
rm ~/Downloads/CascadiaMono.zip

# Setting up symlinks
mkdir -p ~/.config
ln -sfT ~/.dotfiles/.zshrc ~/.zshrc
ln -sfT ~/.dotfiles/.tmux.conf ~/.tmux.conf
ln -sfT ~/.dotfiles/.xkb ~/.xkb

ln -sfT ~/.dotfiles/nvim-main ~/.config/nvim
ln -sfT ~/.dotfiles/starship.toml ~/.config/starship.toml
ln -sfT ~/.dotfiles/foot ~/.config/foot
ln -sfT ~/.dotfiles/sway ~/.config/sway
ln -sfT ~/.dotfiles/fuzzel ~/.config/fuzzel
ln -sfT ~/.dotfiles/waybar ~/.config/waybar
ln -sfT ~/.dotfiles/luakit ~/.config/luakit
ln -sfT ~/.dotfiles/mako ~/.config/mako

# Configure git
zsh ~/.dotfiles/setup_git.bash

# Generate ssh keys
HOSTNAME=github.com USER=git AKtoA=15m zsh ~/.dotfiles/setup_ssh.bash

# make scripts directory
mkdir -p ~/Scripts

rustup install stable -c rust-analyzer
rustup install nightly -c rust-analyzer
cargo install worst --git https://github.com/aaronv15/worst.git
worst-switcher setup --place-config --generate-script ~/Scripts/worst-runner.bash
