# # waybar # apparently already installed?
# sudo pacman -S waybar

# on a laptop install tlp for power management
if [[ -z $LAPTOP ]]; then
   sudo pacman -S tlp ethtool smartmontools
   sudo systemctl enable tlp --now
fi

# install app picker/launcher fuzzel
sudo pacman -S fuzzel

# Zip/unzip
sudo pacman -S zip unzip

# enable keyd
sudo systemctl enable keyd --now

# install fonts:
wget -O ~/Downloads/CascadiaMono.zip https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/CascadiaMono.zip
mkdir -p ~/.local/share/fonts # make font dir if not existing
unzip ~/Downloads/CascadiaMono.zip -d ~/.local/share/fonts
rm ~/Downloads/CascadiaMono.zip

# Setting up symlinks
ln -sT ~/.dotfiles/.zshrc ~/.zshrc
ln -sT ~/.dotfiles/.tmux.conf ~/.tmux.conf

ln -sT ~/.dotfiles/nvim-main ~/.config/nvim
ln -sT ~/.dotfiles/starship.toml ~/.config/starship.toml
ln -sT ~/.dotfiles/foot ~/.config/foot
ln -sT ~/.dotfiles/git ~/.config/git
ln -sT ~/.dotfiles/sway ~/.config/sway
ln -sT ~/.dotfiles/fuzzel ~/.config/fuzzel
ln -sT ~/.dotfiles/waybar ~/.config/waybar
ln -sT ~/.dotfiles/.xkb ~/.xkb
ln -sT ~/.dotfiles/keyd /etc/keyd

# Generate ssh keys
echo "Generate ssh keys"
