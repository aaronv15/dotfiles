# install man pages
pacman -S man-db

# starship for a nice prompt since I can't be bothered to write my own right now
pacman -S starship

# wl-clipoard for wl-copy and wl-paste
sudo pacman -S wl-clipboard
# depends on the above
sudo pacman -S cliphist

# wofi for select menu (Not sure what to call it)
sudo pacman -S wofi

# keyd for keyboard management
sudo pacman -S keyd
# enable it
sudo systemctl enable keyd --now

# assumes you are running in the project root directory
# Setting up symlinks
ln -sT .zshrc ~/.zshrc
ln -sT .tmux.conf ~/.tmux.conf

ln -sT ~/.dotfiles/nvim-main ~/.config/nvim
ln -sT ~/.dotfiles/starship.toml ~/.config/starship.toml
ln -sT ~/.dotfiles/foot ~/.config/foot
ln -sT ~/.dotfiles/git ~/.config/git
ln -sT ~/.dotfiles/sway ~/.config/sway
ln -sT ~/.dotfiles/keyd /etc/keyd

# Generate ssh keys
echo "Generate ssh keys"
